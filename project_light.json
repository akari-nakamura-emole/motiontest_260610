  "scripts": {
    "9bc34542-023f-4819-9c01-dd2d9265935d": [
      {
        "name": "test",
        "source": "var names = [\n  \"circle_tube\",\n  \"e_tube\",\n  \"e_block\",\n  \"circle_eggblock\"\n];\n\nvar items = [];\nvar current = 0;\nvar lastTime = 0;\n\nvar interval = 1000;\nvar popTime = 300;\nvar popScale = 1.18;\n\nvar phase = \"pop\"; // pop / spin\n\nvar eggAxis = new THREE.Vector3(1, 0, -1).normalize();\nvar popAxis = new THREE.Vector3(-1, 0, 2).normalize();\n\nfunction init() {\n  items = names\n    .map(function (name) {\n      return this.getObjectByName(name);\n    }, this)\n    .filter(Boolean);\n\n  items.forEach(function (obj, i) {\n    obj.userData.baseScale = obj.scale.clone();\n    obj.userData.baseQuaternion = obj.quaternion.clone();\n    obj.visible = i === 0;\n  });\n\n  current = 0;\n  lastTime = performance.now();\n  phase = \"pop\";\n}\n\nfunction update() {\n  if (items.length === 0) return;\n\n  var now = performance.now();\n  var t = now - lastTime;\n  var obj = items[current];\n\n  if (phase === \"pop\") {\n    var p = Math.min(t / popTime, 1);\n    var ease = 1 - Math.pow(1 - p, 3);\n    var s = popScale + (1 - popScale) * ease;\n\n    obj.scale.set(\n      obj.userData.baseScale.x * s,\n      obj.userData.baseScale.y * s,\n      obj.userData.baseScale.z * s\n    );\n\n    if (current === 0) {\n\n  // circle_tube\n\t  obj.quaternion.copy(obj.userData.baseQuaternion);\n\n\t}\n\telse if (current === 2) {\n\n\t  // e_block\n\t  obj.quaternion.copy(obj.userData.baseQuaternion);\n\n\t}\n\telse if (current === items.length - 1) {\n\n\t  // circle_eggblock\n\t  var popAngle = (1 - ease) * Math.PI * 2;\n\t  var continuousAngle = t * 0.003;\n\n\t  obj.quaternion.copy(obj.userData.baseQuaternion);\n\n\t  obj.quaternion.multiply(\n\t\tnew THREE.Quaternion().setFromAxisAngle(\n\t\t  eggAxis,\n\t\t  popAngle + continuousAngle\n\t\t)\n\t  );\n\n\t}\n\telse {\n\n\t  // e_tube\n\t  var angle = (1 - ease) * Math.PI * 2;\n\n\t  obj.quaternion.copy(obj.userData.baseQuaternion);\n\n\t  obj.quaternion.multiply(\n\t\tnew THREE.Quaternion().setFromAxisAngle(\n\t\t  popAxis,\n\t\t  angle\n\t\t)\n\t  );\n\n\t}\n\n    if (t > interval) {\n      // 最後のeggは消さず、そのままspinへ\n      if (current === items.length - 1) {\n        obj.scale.copy(obj.userData.baseScale);\n        phase = \"spin\";\n        return;\n      }\n\n      obj.visible = false;\n\n      current++;\n\n      items[current].visible = true;\n      items[current].scale.copy(items[current].userData.baseScale);\n      items[current].quaternion.copy(items[current].userData.baseQuaternion);\n\n      lastTime = now;\n    }\n\n    return;\n  }\n\n  if (phase === \"spin\") {\n    var spinObj = items[items.length - 1];\n    var spinT = now - lastTime;\n    var angle = spinT * 0.003;\n\n    spinObj.quaternion.copy(spinObj.userData.baseQuaternion);\n    spinObj.quaternion.multiply(\n      new THREE.Quaternion().setFromAxisAngle(\n        eggAxis,\n        angle\n      )\n    );\n  }\n}\n\t\n\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t\n\t"
      }
    ]
  },
